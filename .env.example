# Docker display forwarding (optional; required for pygame window in container on Linux/X11)
DISPLAY=<YOUR_DISPLAY_VALUE>

# Training service defaults used by docker-compose.yml
REWARD_TYPE=<baseline_or_shaped>
TIMESTEPS=<TRAINING_TIMESTEPS>

# Script argument placeholders for local runs
MODEL_SAVE_PATH=<models/output_model_name>
MODEL_PATH=<models/existing_model_name.zip>
LOG_DIR=<logs_directory>
